<!DOCTYPE html>
<html>
<!-- @import "head" -->
<body>

<!-- @import "header" -->

<section class="hero">
    <img src="src/assets/img/hero.png" alt="Interior Clássico Héritage" class="hero-img">
    
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <h1>Curated Excellence</h1>
        <p>Timeless pieces that transcend centuries</p>
    </div>
</section>

<!-- @import "featured" -->

  <section class="mission-section">
    <div class="mission-container">
        <h2 class="mission-title">Where History Meets Elegance</h2>
        
        <blockquote class="mission-quote">
            "Every piece tells a story. Every story deserves to be preserved."
        </blockquote>

        <div class="mission-text">
            <p>Since 1982, Héritage has been a sanctuary for the world's finest antiques and decorative arts. We believe that true luxury lies not in the new, but in the enduring beauty of objects that have witnessed history unfold.</p>
            
            <p>Our curators travel across Europe and beyond, meticulously selecting pieces that embody exceptional craftsmanship, provenance, and artistic merit. From Baroque grandeur to Art Nouveau fluidity, each acquisition represents a chapter in the ongoing narrative of human creativity.</p>
            
            <p>We don't just sell antiques — we preserve legacies, honor artisans, and connect collectors with objects that will define their own heritage for generations to come.</p>
        </div>
    </div>
  </section>

<!-- @import "upcoming-auctions" -->

  <section class="styles-gallery">
    <div class="container">
        <header class="section-header">
            <h2>Art by Style</h2>
            <p>Explore different artistic movements</p>
        </header>

        <div class="gallery-grid">
            <div class="gallery-item baroque">
                <img src="src/assets/img/baroque.png" alt="Baroque">
                <span class="style-label">Baroque</span>
            </div>

            <div class="gallery-item modernism">
                <img src="src/assets/img/modernism.png" alt="Modernism">
                <span class="style-label">Modernism</span>
            </div>

            <div class="gallery-item renaissance">
                <img src="src/assets/img/renaissance.png" alt="Renaissance">
                <span class="style-label">Renaissance</span>
            </div>

            <div class="gallery-item sacred">
                <img src="src/assets/img/sacred-art.png" alt="Sacred Art">
                <span class="style-label">Sacred Art</span>
            </div>

            <div class="gallery-item nouveau">
                <img src="src/assets/img/art-nouveau.png" alt="Art Nouveau">
                <span class="style-label">Art Nouveau</span>
            </div>

            <div class="gallery-item neoclassical">
                <img src="src/assets/img/neoclassical.png" alt="Neoclassical">
                <span class="style-label">Neoclassical</span>
            </div>

            <div class="gallery-item abstract">
                <img src="src/assets/img/abstract.png" alt="Abstract">
                <span class="style-label">Abstract</span>
            </div>

            <div class="gallery-item deco">
                <img src="src/assets/img/art-deco.png" alt="Art Deco">
                <span class="style-label">Art Deco</span>
            </div>

            <div class="gallery-item rococo">
                <img src="src/assets/img/rococo.png" alt="Rococo">
                <span class="style-label">Rococo</span>
            </div>
        </div>
    </div>
</section>

<!-- @import "categories" -->

<!-- @import "footer" -->

</body>
</html>