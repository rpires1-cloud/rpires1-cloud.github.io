<!DOCTYPE html>
<html>
<!-- @import "head" -->
<body>

  <!-- @import "header" -->

  <main class="contact-page">
  
        <!-- Banner Superior -->
        <section class="contact-hero">
            <img src="src/assets/img/hero-contacts.png" alt="Antique Lamps">
            <div class="hero-title">
                <h1>GET IN <em>TOUCH</em></h1>
                <p>We'd love to hear from you</p>
            </div>
        </section>

        <!-- Secção de Informação -->
        <section class="contact-info-section container">
            <div class="info-grid">
                <!-- Coluna Esquerda -->
                <div class="info-intro">
                    <h2>CONTACT INFORMATION</h2>
                    <p>Whether you're looking for a specific piece, have questions about our collection, or wish to schedule a private viewing, our team is here to assist you.</p>
                    
                    <div class="private-viewing-box">
                        <h3>Private Viewings</h3>
                        <p>We offer private viewings by appointment for serious collectors. Contact us to arrange a personalized consultation with our expert team.</p>
                    </div>
                </div>

                <!-- Coluna Direita: Ícones e Detalhes -->
                <div class="info-details">
                    <div class="detail-item">
                        <div class="icon-circle">
                            <img src="src/assets/svg/location.svg" alt="Location Icon" class="contact-icon">
                        </div>
                        <div>
                            <h4>VISIT OUR SHOWROOM</h4>
                            <p>123 Flores Street<br>1200-001 Lisbon, Portugal</p>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="icon-circle">
                            <img src="src/assets/svg/email.svg" alt="Email Icon" class="email-icon">
                        </div>
                        <div>
                            <h4>EMAIL US</h4>
                            <p>info@heritage.pt<br>acquisitions@heritage.pt</p>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="icon-circle">
                          <img src="src/assets/svg/phone.svg" alt="Phone Icon" class="phone-icon">
                        </div>
                        <div>
                            <h4>CALL US</h4>
                            <p>+351 21 123 4567<br>+351 96 789 0123</p>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="icon-circle">
                          <img src="src/assets/svg/clock.svg" alt="Clock Icon" class="clock-icon">
                        </div>
                        <div>
                            <h4>OPENING HOURS</h4>
                            <p>Monday - Friday: 10am - 7pm<br>Saturday: 10am - 2pm<br>Sunday: Closed</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Secção do Mapa -->
        <section class="contact-map">
            <iframe 
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3352.552694961163!2d-9.143477123966672!3d38.70921465778556!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd19347eb98de3c5%3A0x9a87ee8e4c380fe!2sFaculdade%20de%20Belas-Artes%2C%201200-227%20Lisboa!5e1!3m2!1spt-PT!2spt!4v1778772047328!5m2!1spt-PT!2spt" width="1200" height="600" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </iframe>
        </section>
    </main>

  
  <!-- @import "footer" -->

</body>
</html>