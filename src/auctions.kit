<!DOCTYPE html>
<html>
<!-- @import "head" -->
<body>

  <!-- @import "header" -->

<main>
  <div class="history-banner">
    <img src="src/assets/img/Auction-Banner.png" alt="Gavel">
  </div>
  <div class="hero-title">
    <h1>Our <span>Auctions</span></h1>
    <p>Participate in the legacy of timeless craftsmanship</p>
  </div>

  <!-- UPCOMING AUCTIONS -->
  <section class="upcoming-auctions">
    <div class="auctions-heading">
      <h2>Upcoming Auctions</h2>
      <p>Mark your calendar for these exclusive events</p>
    </div>
    <div class="auction-grid">
      <div class="auction-card red">
        <div>
          <p class="auction-date">28 April 2026</p>
          <h3>Spring Auction</h3>
          <p>18th-century French furniture and decorative arts</p>
        </div>
        <div class="auction-meta">
          <span>42 lots</span>
          <span>14:00 GMT</span>
        </div>
      </div>

      <div class="auction-card gold">
        <div>
          <p class="auction-date">15 May 2026</p>
          <h3>Private Collection</h3>
          <p>Sacred art and liturgical objects from European churches</p>
        </div>
        <div class="auction-meta">
          <span>28 lots</span>
          <span>15:00 GMT</span>
        </div>
      </div>

      <div class="auction-card dark">
        <div>
          <p class="auction-date">5 June 2026</p>
          <h3>European Rarities</h3>
          <p>Antique clocks, scientific instruments, and curiosities</p>
        </div>
        <div class="auction-meta">
          <span>35 lots</span>
          <span>14:00 GMT</span>
        </div>
      </div>

      <div class="auction-card olive">
        <div>
          <p class="auction-date">22 June 2026</p>
          <h3>Summer Estate Sale</h3>
          <p>Fine furniture, paintings, and silverware</p>
        </div>
        <div class="auction-meta">
          <span>58 lots</span>
          <span>13:00 GMT</span>
        </div>
      </div>
    </div>
  </section>

  <!-- RECORD SALES -->
  <section class="sales-section">
    <div class="container">
      <div class="section-heading">
        <h2>Recent Record Sales</h2>
        <p>Top bids from our past auctions</p>
      </div>

      <div class="sales-grid">
        <div class="sale-card">
          <img src="src/assets/img/Baroque-Clock.png" alt="Imperial clock">
          <div class="sale-content">
            <div class="sale-era">18th Century</div>
            <h3>Imperial Baroque Clock</h3>
            <div class="sale-footer">
              <div class="sale-price">€12,400</div>
              <span>March 2026</span>
            </div>
          </div>
        </div>

        <div class="sale-card">
          <img src="src/assets/img/Gilded-Mirror.png" alt="Victorian mirror">
          <div class="sale-content">
            <div class="sale-era">19th Century</div>
            <h3>Victorian Gilded Mirror</h3>
            <div class="sale-footer">
              <div class="sale-price">€9,800</div>
              <span>February 2026</span>
            </div>
          </div>
        </div>

        <div class="sale-card">
          <img src="src/assets/img/Crystal-Chandelier.png" alt="Crystal chandelier">
            <div class="sale-content">
              <div class="sale-era">Art Nouveau</div>
              <h3>Crystal Chandelier</h3>
              <div class="sale-footer">
                <div class="sale-price">€15,200</div>
                <span>January 2026</span>
              </div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PARTICIPATE -->
  <section class="container">
    <div class="participate-header">
      <h2>How to <span>Participate</span></h2>
      <p>Important guidelines and rules for bidding at HÉRITAGE auctions</p>
    </div>

    <div class="participate-grid">
      <div class="participate-card">
        <div class="participate-icon">◫</div>
          <div>
            <h3>Registration</h3>
            <p>All bidders must register at least 48 hours before the auction. Valid identification and proof of funds may be required.</p>
          </div>
      </div>

      <div class="participate-card">
        <div class="participate-icon">⬡</div>
          <div>
            <h3>Buyer’s Premium</h3>
            <p>A buyer’s premium of 25% is added to the hammer price. This includes insurance and handling.</p>
          </div>
      </div>

      <div class="participate-card">
        <div class="participate-icon">◷</div>
          <div>
            <h3>Payment Terms</h3>
            <p>Payment is due within 7 business days of the auction. We accept bank transfers and major cards.</p>
          </div>
      </div>

      <div class="participate-card">
        <div class="participate-icon">⌁</div>
        <div>
          <h3>Bidding Increments</h3>
          <p>Bidding increments vary by lot value. Typically €100 for lots under €5,000 and higher for premium lots.</p>
        </div>
      </div>

      <div class="participate-card">
        <div class="participate-icon">◎</div>
          <div>
            <h3>Absentee</h3>
            <p>Cannot attend in person? Submit absentee bids or arrange phone bidding by contacting us in advance.</p>
          </div>
      </div>

      <div class="participate-card">
        <div class="participate-icon">▣</div>
          <div>
            <h3>Viewing Schedule</h3>
            <p>All lots are available for viewing 3 days prior to auction during business hours.</p>
          </div>
      </div>
    </div>
  </section>
</main>
  
  <!-- @import "footer" -->

</body>
</html>